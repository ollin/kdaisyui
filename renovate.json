{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "labels": ["dependencies"],
  "assignees": ["ollin"],
  "reviewers": ["ollin"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "schedule": ["at any time"],
  "timezone": "Europe/Berlin",
  "dryRun": null,
  "semanticCommits": "enabled",
  "commitMessagePrefix": "chore(deps):",

  "packageRules": [
    {
      "description": "Group all Ktor updates into one PR",
      "groupName": "Ktor",
      "groupSlug": "ktor",
      "matchPackageNames": [
        "io.ktor{/,}**"
      ]
    },
    {
      "description": "Group all webjars updates into one PR",
      "groupName": "webjars",
      "groupSlug": "webjars",
      "matchPackageNames": [
        "org.webjars{/,}**"
      ]
    },
    {
      "description": "Group all Kotlin-related updates into one PR",
      "matchPackageNames": [
        "org.jetbrains.kotlin.jvm",
        "org.jetbrains.kotlinx:kotlinx-html-jvm"
      ],
      "groupName": "Kotlin",
      "groupSlug": "kotlin"
    },
    {
      "description": "Automerge patch updates for Playwright",
      "matchPackageNames": ["@playwright/test"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Pin GitHub Actions to digest for security",
      "matchManagers": ["github-actions"],
      "pinDigests": false
    }
  ],

  "gradle": {
    "enabled": true,
    "managerFilePatterns": [
      "/(^|/)build\.gradle\.kts$/",
      "/(^|/)settings\.gradle\.kts$/",
      "/(^|/)gradle\.properties$/",
      "/(^|/)buildSrc/.+\.gradle\.kts$/"
    ]
  },

  "npm": {
    "enabled": true,
    "managerFilePatterns": [
      "/(^|/)e2e-tests/package\.json$/"
    ]
  },

  "github-actions": {
    "enabled": true,
    "managerFilePatterns": [
      "/^\.github/workflows/[^/]+\.ya?ml$/"
    ]
  }
}
